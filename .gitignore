# Rename to .gitignore

# Dependencies / build (anchored to repo root so source dirs like src/build/ are kept)
node_modules/
/dist/
/build/
coverage/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# Secrets — never commit
.env
*.env
.env.*
*.key
*.pem
*.p12
*.pfx
*secret*
*credential*
*token*
*service*account*.json

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Playwright
test-results/
playwright-report/
.playwright/

# Demo build
demo/dist/

# Session handover notes (never commit, any location)
HANDOVER.md
